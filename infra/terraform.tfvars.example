# Copy this to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored (contains your IP + key path).

# Your public IP as a /32 CIDR. Find it with:  curl -s https://checkip.amazonaws.com
my_ip = "102.40.123.180/32"

# Path to your SSH *public* key.
# Windows example (Git Bash path):  /c/Users/Mostafa Abdelaal/.ssh/id_ed25519.pub
ssh_public_key_path = "C:/Users/Mostafa Abdelaal/.ssh/id_ed25519.pub"

# Optional overrides (defaults shown):
# region        = "us-east-1"
# instance_type = "t3.micro"
# repo_branch   = "main"
