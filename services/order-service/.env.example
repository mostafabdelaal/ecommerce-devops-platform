# -----------------------------------------------------------------------------
# CloudMart backend configuration
# Copy this file to `.env` and adjust values for your environment.
# The application reads ALL configuration from these variables.
# -----------------------------------------------------------------------------

# HTTP port the backend listens on
PORT=3000

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=cloudmart
DB_PASSWORD=cloudmart
DB_NAME=cloudmart

# Startup database connection resilience
# How many times to retry connecting to Postgres at startup, and the delay
# between attempts (in milliseconds).
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=3000
