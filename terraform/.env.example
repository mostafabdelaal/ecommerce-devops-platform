# Copy to terraform/.env (gitignored). providers.tf reads AWS_ACCOUNT_ID from
# here to pin allowed_account_ids so you can't apply against the wrong account.
AWS_ACCOUNT_ID=004595030618

# Only for the domain/HTTPS path (acm.tf, external-dns). Leave unset for the
# domain-less deploy. TF_VAR_* are picked up automatically as terraform vars.
# TF_VAR_domain_name=example.com
# TF_VAR_hosted_zone_id=Z0123456789ABCDEF
